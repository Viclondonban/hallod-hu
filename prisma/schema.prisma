generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Podcast {
  id            String   @id @default(cuid())
  title         String
  slug          String?  @unique
  isActive      Boolean  @default(true)
  bannerImageUrl String?
  isFeatured     Boolean  @default(false)
  description   String?
  author        String?
  feedUrl       String   @unique
  imageUrl      String?
  websiteUrl    String?
  language      String?  @default("hu")
  category      String?  @default("Egyéb")
  lastCheckedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastError     String?

  episodes      Episode[]
}

model Episode {
  id            String   @id @default(cuid())
  podcastId     String
  podcast       Podcast  @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  guid          String 
  title         String
  description   String?
  pubDate       DateTime 
  enclosureUrl  String 
  duration      Int? 
  episodeNumber Int?
  imageUrl      String? 
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([podcastId, guid])
  @@index([pubDate])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
}

model Suggestion {
  id        String   @id @default(cuid())
  content   String   
  ipAddress String?  @default("unknown")
  createdAt DateTime @default(now())
}