// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// The Models (Our Database Tables)
// ==========================================

model Podcast {
  id            String    @id @default(cuid())
  slug          String?   @unique   
  
  title         String
  description   String?
  author        String?
  websiteUrl    String?   
  feedUrl       String    @unique 
  imageUrl      String?   
  language      String?   
  lastBuildDate DateTime? 

  // Platform Logic
  isFeatured Boolean @default(false)
  bannerImageUrl String?  
  category       String?  
  isActive   Boolean @default(true)

  // System / Maintenance timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastCheckedAt DateTime? 

  // Relationship: One podcast has many episodes
  episodes Episode[]
}

model Episode {
  id String @id @default(cuid())

  // Link back to the Podcast table
  podcastId String
  podcast   Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  guid String 

  title         String
  description   String?
  pubDate       DateTime 
  enclosureUrl  String 
  duration      Int? 
  episodeNumber Int?
  imageUrl      String? 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([podcastId, guid])
  @@index([pubDate])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
}