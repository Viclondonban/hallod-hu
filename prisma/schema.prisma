generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Podcast {
  id             String    @id @default(cuid())
  title          String
  description    String?
  author         String?
  websiteUrl     String?
  feedUrl        String    @unique
  imageUrl       String?
  language       String?   @default("hu")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastCheckedAt  DateTime  @default(now())
  category       String?   @default("Egyéb")
  lastError      String?
  slug           String?   @unique
  bannerImageUrl String?
  isActive       Boolean   @default(true)
  isFeatured     Boolean   @default(false)
  nextCheckAt       DateTime  @default(now())
  feedEtag          String?
  feedLastModified  String?
  episodes          Episode[]

  @@index([category])
  @@index([isActive])
  @@index([isFeatured])
  @@index([isActive, nextCheckAt])
}

model Episode {
  id            String   @id @default(cuid())
  podcastId     String
  guid          String
  title         String
  description   String?
  pubDate       DateTime
  enclosureUrl  String
  duration      Int?
  episodeNumber Int?
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  podcast       Podcast  @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@unique([podcastId, guid])
  @@index([pubDate])
}

model Category {
  id        String @id @default(cuid())
  name      String @unique
  sortOrder Int    @default(0)
}

model Suggestion {
  id        String   @id @default(cuid())
  content   String
  ipAddress String?  @default("unknown")
  createdAt DateTime @default(now())
}
